# hello
# ── Clerk ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Convex ─────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=          # from `npx convex dev` output
CONVEX_DEPLOY_KEY=               # from Convex dashboard → Settings

# ── Gemini (set in Convex, not Vercel) ─────────────
# Run: npx convex env set GEMINI_API_KEY your_key_here
GEMINI_API_KEY=

# ── Resend (set in Convex, not Vercel) ─────────────
# Run: npx convex env set RESEND_API_KEY your_key_here
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── PostHog ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── App URL ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
